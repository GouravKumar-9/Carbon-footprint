# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git

# Groq AI API key (required for AI chat)
GROQ_API_KEY=your_groq_api_key_here

# JWT secret for session signing (min 32 chars, use random hex)
# Generate: node -e "require('crypto').randomBytes(32).toString('hex').then?console.log:console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_min_32_chars

# Login credentials
ADMIN_EMAIL=gaurav@carbontrack.in

# bcrypt hash of your password (cost factor 12)
# Generate: node -e "require('bcryptjs').hash('yourpassword',12).then(h=>console.log(h))"
# Default hash below is for 'greenplanet2026'
ADMIN_PASSWORD_HASH=$2a$12$LIBAd1BKgx4mz0TQpkNhbuY2O1JxS7L/yKKJDJGVQQh4vlqc7kFjq

# Comma-separated list of allowed CORS origins
# Example: https://your-app.run.app,https://carbontrack.in
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Server port (Cloud Run uses 8080 by default)
PORT=3000
