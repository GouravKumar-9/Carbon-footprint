{
  "name": "carbontrack-india",
  "version": "1.1.0",
  "description": "CarbonTrack India — carbon footprint web app with AI assistant",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "jest --runInBand --detectOpenHandles",
    "test:coverage": "jest --runInBand --detectOpenHandles --coverage",
    "lint": "eslint server.js public/js/emissions.js"
  },
  "jest": {
    "coverageThreshold": {
      "global": {
        "lines": 75,
        "functions": 75,
        "branches": 70,
        "statements": 75
      }
    },
    "collectCoverageFrom": [
      "server.js",
      "public/js/emissions.js"
    ]
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "groq-sdk": "^1.2.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-plugin-security": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
